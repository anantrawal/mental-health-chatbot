# Copy this to .env and fill in your values
# NEVER commit .env to git

# Optional: Add your Anthropic API key for Claude-powered responses
# Without this, the app uses built-in empathetic responses (still works great)
ANTHROPIC_API_KEY=REMOVED_SECRET

# Security: Change this to a long random string in production
SECRET_KEY=change-me-to-a-random-secret-in-production

# MongoDB (leave as-is for Docker)
MONGODB_URL=mongodb://mongo:27017
DB_NAME=mental_health_db
